# Copy this file to .env before running docker compose.
# Use strong, unique values in production.

# Global application settings
APP_ENV=local
APP_DEBUG=true

MYSQL_ROOT_PASSWORD=rootpassword

# Auth service
AUTH_DB_NAME=fe_auth_db
AUTH_DB_USER=fe_auth_user
AUTH_DB_PASSWORD=auth_db_password
AUTH_APP_KEY=base64:YOUR_AUTH_APP_KEY_HERE
AUTH_JWT_SECRET=replace_with_strong_random_secret

# Booking service
BOOKING_DB_NAME=fe_booking_db
BOOKING_DB_USER=fe_booking_user
BOOKING_DB_PASSWORD=booking_db_password
BOOKING_APP_KEY=base64:YOUR_BOOKING_APP_KEY_HERE
BOOKING_JWT_SECRET=replace_with_strong_random_secret
FINANCE_SERVICE_URL=http://fe-finance-service
HOUSEKEEPING_SERVICE_URL=http://fe-housekeeping-service

# Housekeeping service
HOUSEKEEPING_DB_NAME=fe_housekeeping_db
HOUSEKEEPING_DB_USER=fe_housekeeping_user
HOUSEKEEPING_DB_PASSWORD=housekeeping_db_password
HOUSEKEEPING_APP_KEY=base64:YOUR_HOUSEKEEPING_APP_KEY_HERE
HOUSEKEEPING_JWT_SECRET=replace_with_strong_random_secret
BOOKING_SERVICE_URL=http://fe-booking-service

# Finance service
FINANCE_DB_NAME=fe_finance_db
FINANCE_DB_USER=fe_finance_user
FINANCE_DB_PASSWORD=finance_db_password
FINANCE_APP_KEY=base64:YOUR_FINANCE_APP_KEY_HERE
FINANCE_JWT_SECRET=replace_with_strong_random_secret
